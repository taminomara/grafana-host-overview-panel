{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "panel",
  "name": "Host Overview",
  "id": "taminomara-hostoverview-panel",
  "info": {
    "keywords": ["panel", "overview", "cluster", "compact"],
    "description": "Visualize your resources in a compact table with powerful tooltips and grouping",
    "author": {
      "name": "Tamika Nomara",
      "email": "taminomara@gmail.com"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Documentation",
        "url": "https://grafana-host-overview-panel.readthedocs.io/"
      },
      {
        "name": "Source",
        "url": "https://github.com/taminomara/grafana-host-overview-panel/"
      },
      {
        "name": "Issues",
        "url": "https://github.com/taminomara/grafana-host-overview-panel/issues"
      },
      {
        "name": "Changelog",
        "url": "https://github.com/taminomara/grafana-host-overview-panel/blob/main/CHANGELOG.md"
      }
    ],
    "screenshots": [
      {
        "name": "Overview of nodes and containers",
        "path": "img/screenshots/service.png"
      },
      {
        "name": "Overview of a large data center",
        "path": "img/screenshots/dc.png"
      },
      {
        "name": "Overview of database instances",
        "path": "img/screenshots/db.png"
      }
    ],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "dependencies": {
    "grafanaDependency": ">=12.0.10",
    "plugins": []
  }
