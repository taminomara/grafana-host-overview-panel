        "pluginVersion": "1.0.0",
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "editorMode": "builder",
            "exemplar": false,
            "expr": "up",
            "instant": true,
            "legendFormat": "__auto",
            "range": false,
            "refId": "UP"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "editorMode": "code",
            "expr": "100 * (1 - avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))",
            "hide": false,
            "instant": false,
            "legendFormat": "__auto",
            "range": true,
            "refId": "CPU"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "editorMode": "code",
            "expr": "clamp_min((1 - (node_memory_MemAvailable_bytes / on (instance) node_memory_MemTotal_bytes)) * 100, 0)",
            "hide": false,
            "instant": false,
            "legendFormat": "__auto",
            "range": true,
            "refId": "MEM"
          }
        ],
        "title": "Scraping jobs",
        "transformations": [
          {
            "filter": {
              "id": "byRefId",
              "options": "/^(?:UP)$/"
            },
            "id": "prepareTimeSeries",
            "options": {
              "format": "long"
            }
          },
          {
            "filter": {
              "id": "byRefId",
              "options": "/^(?:A|UP)$/"
            },
            "id": "merge",
            "options": {}
          },
          {
            "filter": {
              "id": "byRefId",
              "options": "/^(?:CPU|MEM)$/"
            },
            "id": "timeSeriesTable",
            "options": {
              "B": {
                "timeField": "Time"
              }
            }
          },
          {
            "id": "extractFields",
            "options": {
              "delimiter": ",",
              "format": "regexp",
              "regExp": "/(?<host>[^:]+)(?::(?<port>\\d+))?/",
              "source": "instance"
            }
          }
        ],
        "transparent": true,
        "type": "taminomara-hostoverview-panel"
      }
